# MarocMarket Environment Configuration

# Database
MARKETPLACE_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marocmarket?schema=public"
MARKETPLACE_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/marocmarket?schema=public"

# Auth
MARKETPLACE_AUTH_SECRET="your-secret-key-change-in-production"
MARKETPLACE_NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers
MARKETPLACE_GOOGLE_CLIENT_ID=""
MARKETPLACE_GOOGLE_CLIENT_SECRET=""
MARKETPLACE_FACEBOOK_CLIENT_ID=""
MARKETPLACE_FACEBOOK_CLIENT_SECRET=""
MARKETPLACE_APPLE_CLIENT_ID=""
MARKETPLACE_APPLE_CLIENT_SECRET=""

# Cloudinary (image hosting)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Stripe (payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""

# Redis (caching, rate limiting, session)
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Elasticsearch (full-text search)
ELASTICSEARCH_URL="http://localhost:9200"
ELASTICSEARCH_API_KEY=""

# Email (Resend)
RESEND_API_KEY=""

# OpenAI (AI features)
OPENAI_API_KEY=""

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MARKETPLACE_NAME="MarocMarket"

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_DESCRIPTION="true"
NEXT_PUBLIC_ENABLE_IMAGE_SEARCH="false"
