{
  "manifest_version": 3,
  "name": "RELURL - URL Shortener",
  "description": "Shorten URLs instantly with RELURL. Create short links, copy them to clipboard, and manage your links on the go.",
  "version": "1.0.0",
  "permissions": ["activeTab", "storage", "clipboardWrite"],
  "host_permissions": ["https://relurl.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
