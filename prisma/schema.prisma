generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  isActive      Boolean   @default(true)
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  campaigns     Campaign[]
  links         ShortLink[]
  apiKeys       ApiKey[]
  subscriptions Subscription[]
  teamMembers   TeamMember[]
  notifications Notification[]
  auditLogs     AuditLog[]
  payments      Payment[]
  invoices      Invoice[]
  domains       Domain[]
  utmCampaigns  UtmCampaign[]
  bioPages      BioPage[]
  reportSchedules ReportSchedule[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Team {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamMembers   TeamMember[]
  subscriptions Subscription[]
  shortLinks    ShortLink[]
  domains       Domain[]
  utmCampaigns  UtmCampaign[]
  auditLogs     AuditLog[]
}

model TeamMember {
  id       String   @id @default(uuid())
  userId   String
  teamId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model ShortLink {
  id               String   @id @default(uuid())
  url              String
  slug             String   @unique
  domain           String   @default("relurl.com")
  title            String?
  description      String?
  tags             String?
  category         String?
  password         String?
  expiresAt        DateTime?
  isActive         Boolean  @default(true)
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmTerm          String?
  utmContent       String?
  geoTargeting     String?
  deviceTargeting  String?
  languageTargeting  String?
  scheduledAt        DateTime?
  userId           String?
  teamId           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastClickedAt    DateTime?

  // Retargeting Pixels
  facebookPixel    String?
  googlePixel      String?
  tiktokPixel      String?
  linkedinPixel    String?
  twitterPixel     String?
  customPixels     String?

  // AI Optimization
  aiBestTime       String?
  aiPredictedCtr   Float?
  aiSuggestions    String?
  aiTrend          String?
  aiHealthScore    Float?
  aiHealthStatus   String?
  aiEstimatedDaysRemaining Float?
  aiWeeklyChange   Float?
  aiRecommendation String?

  healthStatus   String?
  healthCheckedAt DateTime?
  healthStatusCode Int?

  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  team      Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  linkClicks  LinkClick[]
  qrCodes     QrCode[]
  abTests     ABTest[]
  smartRoutes SmartRoute[]
}

model LinkClick {
  id        String   @id @default(uuid())
  linkId    String
  timestamp DateTime @default(now())
  ip        String?
  userAgent String?
  referer   String?
  country   String?
  city      String?
  region    String?
  latitude  Float?
  longitude Float?
  browser   String?
  os        String?
  device    String?
  language  String?
  isUnique      Boolean  @default(false)
  isSuspicious  Boolean  @default(false)

  link ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  key         String    @unique
  userId      String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                  String   @id @default(uuid())
  userId              String
  teamId              String?
  plan                String   @default("FREE")
  status              String   @default("ACTIVE")
  stripeSubscriptionId String?
  stripeCustomerId    String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  canceledAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  payments Payment[]
  invoices Invoice[]
}

model Payment {
  id                   String   @id @default(uuid())
  userId               String
  subscriptionId       String
  stripePaymentIntentId String?
  amount               Int
  currency             String   @default("usd")
  status               String   @default("PENDING")
  createdAt            DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model Invoice {
  id                String   @id @default(uuid())
  userId            String
  subscriptionId    String
  stripeInvoiceId   String?
  amount            Int
  currency          String   @default("usd")
  status            String   @default("UNPAID")
  pdfUrl            String?
  dueDate           DateTime?
  paidAt            DateTime?
  createdAt         DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model Domain {
  id                 String   @id @default(uuid())
  domain             String   @unique
  userId             String
  teamId             String?
  isVerified         Boolean  @default(false)
  verificationMethod String?
  sslStatus          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model QrCode {
  id        String   @id @default(uuid())
  linkId    String
  name      String
  type      String   @default("url")      // url, vcard, wifi, text, email, sms
  content   String?                        // JSON: type-specific content
  design    String?
  size      Int      @default(300)
  format    String   @default("png")
  createdAt DateTime @default(now())

  link ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
}

model UtmCampaign {
  id       String   @id @default(uuid())
  name     String
  userId   String
  teamId   String?
  source   String?
  medium   String?
  campaign String?
  term     String?
  content  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model ABTest {
  id          String   @id @default(uuid())
  linkId      String
  name        String
  urls        String   // JSON array of URLs
  weights     String?  // JSON array of weights
  isActive    Boolean  @default(true)
  winnerUrl   String?
  totalClicks Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  link ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
}

model SmartRoute {
  id          String   @id @default(uuid())
  linkId      String
  name        String
  conditions  String   // JSON: {countries, devices, languages, timeRanges}
  destination String
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  hitCount    Int      @default(0)
  lastHitAt   DateTime?
  utmParams   String?  // JSON: {source, medium, campaign, content, term}
  matchMode   String   @default("first") // "first" (OR) | "all" (AND within routeGroup)
  routeGroup  Int      @default(0)       // Routes with same routeGroup use AND logic
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  link ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
}

model BioPage {
  id          String   @id @default(uuid())
  userId      String
  slug        String   @unique
  title       String
  description String?
  avatar      String?
  theme       String?  // JSON: {background, textColor, buttonStyle}
  isPublic    Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  links    BioLink[]
}

model BioLink {
  id          String   @id @default(uuid())
  pageId      String
  title       String
  url         String
  icon        String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  page BioPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String   @default("#4f46e5")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  links ShortLink[]

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("INFO")
  title     String
  message   String?
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  teamId    String?
  action    String
  entity    String
  entityId  String
  changes   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

model ReportSchedule {
  id          String   @id @default(cuid())
  userId      String   @unique
  frequency   String   // "daily" | "weekly" | "monthly"
  dayOfWeek   Int?     // 0-6 (Sunday-Saturday), for weekly
  dayOfMonth  Int?     // 1-31, for monthly
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive, frequency])
}
