# Database
DATABASE_URL="postgresql://user:password@localhost:5432/relurl"
DIRECT_URL="postgresql://user:password@localhost:5432/relurl"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Email (Resend)
RESEND_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Paddle
PADDLE_API_KEY=""
PADDLE_CLIENT_TOKEN=""
PADDLE_WEBHOOK_SECRET=""
NEXT_PUBLIC_PADDLE_ENV="sandbox"
NEXT_PUBLIC_PADDLE_PRICE_PRO=""
NEXT_PUBLIC_PADDLE_PRICE_BUSINESS=""
NEXT_PUBLIC_PADDLE_PRICE_PRO_ANNUAL=""
NEXT_PUBLIC_PADDLE_PRICE_BUSINESS_ANNUAL=""
NEXT_PUBLIC_PADDLE_PRICE_ENTERPRISE=""
NEXT_PUBLIC_PADDLE_PRICE_ENTERPRISE_ANNUAL=""

# App
APP_URL="http://localhost:3000"

# Redis (Upstash - serverless Redis for rate limiting, caching, and analytics)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron
CRON_SECRET=

# Google Indexing API
# Option A: base64-encoded JSON key (preferred for Vercel/serverless)
GOOGLE_INDEXING_KEY="base64-encoded-json-here"
# Option B: file path to JSON key (local dev only - file must be in project scope)
# GOOGLE_INDEXING_KEY_PATH="./relurlwebsite-key.json"
